# Backend
ConnectionStrings__Default=Server=localhost;Port=3306;Database=tunefinder_ai;User ID=root;Password=yourpassword;SslMode=None;
# Heroku MySQL/JawsDB URL alternative (use this on Heroku if provided)
JAWSDB_URL=mysql://user:password@host:3306/database_name

# AI provider config (OpenAI-compatible)
Ai__BaseUrl=https://api.openai.com/v1
Ai__ApiKey=your_api_key_here
Ai__ChatModel=gpt-4o-mini
Ai__EmbeddingModel=text-embedding-3-small
Ai__Temperature=0.7

# Frontend (optional global var usage)
# window.TUNEFINDER_API_BASE_URL in frontend host can point to deployed backend URL
